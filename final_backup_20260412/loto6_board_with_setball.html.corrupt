": 41, "sum": 110}, {"id": "隨ｬ21蝗・, "date": "2001/2/22", "set_ball": "C", "numbers": [5, 7, 13, 19, 38, 41], "bonus": 42, "sum": 123}, {"id": "隨ｬ20蝗・, "date": "2001/2/15", "set_ball": "D", "numbers": [7, 29, 33, 35, 37, 39], "bonus": 19, "sum": 180}, {"id": "隨ｬ19蝗・, "date": "2001/2/8", "set_ball": "B", "numbers": [4, 8, 12, 30, 33, 43], "bonus": 14, "sum": 130}, {"id": "隨ｬ18蝗・, "date": "2001/2/1", "set_ball": "H", "numbers": [6, 16, 18, 27, 36, 41], "bonus": 33, "sum": 144}, {"id": "隨ｬ17蝗・, "date": "2001/1/25", "set_ball": "G", "numbers": [14, 20, 25, 34, 35, 36], "bonus": 11, "sum": 164}, {"id": "隨ｬ16蝗・, "date": "2001/1/18", "set_ball": "A", "numbers": [5, 12, 13, 29, 34, 35], "bonus": 30, "sum": 128}, {"id": "隨ｬ15蝗・, "date": "2001/1/11", "set_ball": "I", "numbers": [4, 6, 11, 20, 21, 28], "bonus": 36, "sum": 90}, {"id": "隨ｬ14蝗・, "date": "2001/1/4", "set_ball": "F", "numbers": [2, 8, 11, 35, 37, 38], "bonus": 43, "sum": 131}, {"id": "隨ｬ13蝗・, "date": "2000/12/28", "set_ball": "H", "numbers": [13, 29, 31, 37, 41, 42], "bonus": 17, "sum": 193}, {"id": "隨ｬ12蝗・, "date": "2000/12/21", "set_ball": "E", "numbers": [14, 17, 27, 28, 35, 39], "bonus": 22, "sum": 160}, {"id": "隨ｬ11蝗・, "date": "2000/12/14", "set_ball": "D", "numbers": [12, 26, 32, 37, 40, 42], "bonus": 16, "sum": 189}, {"id": "隨ｬ10蝗・, "date": "2000/12/7", "set_ball": "J", "numbers": [1, 3, 19, 21, 35, 39], "bonus": 26, "sum": 118}, {"id": "隨ｬ9蝗・, "date": "2000/11/30", "set_ball": "C", "numbers": [11, 19, 23, 38, 39, 42], "bonus": 15, "sum": 172}, {"id": "隨ｬ8蝗・, "date": "2000/11/23", "set_ball": "B", "numbers": [11, 16, 18, 20, 42, 43], "bonus": 28, "sum": 150}, {"id": "隨ｬ7蝗・, "date": "2000/11/16", "set_ball": "E", "numbers": [7, 19, 21, 23, 33, 35], "bonus": 26, "sum": 138}, {"id": "隨ｬ6蝗・, "date": "2000/11/9", "set_ball": "I", "numbers": [6, 12, 23, 25, 28, 38], "bonus": 22, "sum": 132}, {"id": "隨ｬ5蝗・, "date": "2000/11/2", "set_ball": "F", "numbers": [9, 15, 21, 23, 27, 28], "bonus": 43, "sum": 123}, {"id": "隨ｬ4蝗・, "date": "2000/10/26", "set_ball": "H", "numbers": [16, 18, 26, 27, 34, 40], "bonus": 13, "sum": 161}, {"id": "隨ｬ3蝗・, "date": "2000/10/19", "set_ball": "C", "numbers": [1, 5, 15, 31, 36, 38], "bonus": 13, "sum": 126}, {"id": "隨ｬ2蝗・, "date": "2000/10/12", "set_ball": "G", "numbers": [1, 9, 16, 20, 21, 43], "bonus": 5, "sum": 110}, {"id": "隨ｬ1蝗・, "date": "2000/10/5", "set_ball": "A", "numbers": [2, 8, 10, 13, 27, 30], "bonus": 39, "sum": 90}];
        window.eliminatedNumbers = [];
        window.riverRocks = [];

        function renderBoard() {
            const h1 = document.getElementById('headerRow1');
            let h1Html = '';
            for(let i=1; i<=43; i++) {
                h1Html += `<th id="th-${i}"><div id="hnum-${i}" class="header-num" onclick="handleHeaderClick(${i})">${i < 10 ? '0'+i : i}</div></th>`;
            }
            h1.innerHTML = h1Html;

            const tb = document.getElementById('tableBody');
            let b = "";
            lotoData.forEach(d => {
                b += `<tr><td class="id-col" style="white-space:nowrap; font-size:11px;">${d.id}</td><td class="sb-col">${d.set_ball}</td>`;
                for(let i=1; i<=43; i++) {
                    const isBonus = (d.bonus === i);
                    const isActive = d.numbers.includes(i);
                    const cellClass = (isActive ? 'active' : '') + (isBonus ? ' is-bonus' : '');
                    
                    let innerContent = "";
                    if (isActive || isBonus) {
                        const colClass = isActive ? ` col-${i%10}` : '';
                        const innerClass = `num-cell${colClass}${isBonus ? ' bonus-cell' : ''}`;
                        innerContent = `<div class="${innerClass}">${i}</div>`;
                    }
                    
                    b += `<td class="${cellClass}" data-num="${i}">
                            ${innerContent}
                          </td>`;
                }
                b += `</tr>`;
            });
            tb.innerHTML = b;
            
            initSetBall();
            updateStats();
        }

        function toggleElimModeUI() {
            const mode = document.querySelector('input[name="elim_mode"]:checked').value;
            const table = document.getElementById('mainTable');
            if (mode === 'manual') {
                table.classList.add('manual-mode');
            } else {
                table.classList.remove('manual-mode');
            }
            
            // 繝｢繝ｼ繝牙・繧頑崛縺域凾縺ｫ髯､螟匁焚蟄励ｒ繝ｪ繧ｻ繝・ヨ
            window.eliminatedNumbers = [];
            refreshAllElimCells();
        }

        function resetConditions() {
            // 蜈･蜉幃・岼縺ｮ繝ｪ繧ｻ繝・ヨ
            document.getElementById('minSumInput').value = 60;
            document.getElementById('maxSumInput').value = 200;
            document.getElementById('oddsInput').value = "";
            document.getElementById('setBallSelect').value = "";
            document.getElementById('consecutiveInput').value = "";
            document.getElementById('lastDigitInput').value = "";
            for(let i=1; i<=5; i++) document.getElementById('f'+i).value = "";
            
            // 蟾晉炊隲悶・繝ｪ繧ｻ繝・ヨ
            window.riverMode = false;
            window.riverRocks = [];
            document.getElementById('btnRiver').classList.remove('active');
            document.getElementById('riverText').style.display = 'none';
            
            // 髯､螟悶Δ繝ｼ繝峨ｒ閾ｪ蜍輔↓謌ｻ縺励※繝ｪ繧ｻ繝・ヨ
            const autoRadio = document.querySelector('input[name="elim_mode"][value="auto"]');
            if(autoRadio) {
                autoRadio.checked = true;
                toggleElimModeUI();
            }

            // 縺昴・莉冶｡ｨ遉ｺ縺ｮ譖ｴ譁ｰ
            updateEvens();
            onSetBallChange();
            
            // 莠域ｸｬ邨先棡陦ｨ遉ｺ繧よｶ亥悉
            document.getElementById('predictText').style.display = 'none';
            window.currentPrediction = null;
            renderPredictionOnHeader([]);

            alert("譚｡莉ｶ繧偵☆縺ｹ縺ｦ繝ｪ繧ｻ繝・ヨ縺励∪縺励◆縲・);
        }

        function handleHeaderClick(n) {
            const mode = document.querySelector('input[name="elim_mode"]:checked').value;
            if (mode !== 'manual') return;

            if (window.eliminatedNumbers.includes(n)) {
                window.eliminatedNumbers = window.eliminatedNumbers.filter(x => x !== n);
            } else {
                window.eliminatedNumbers.push(n);
            }
            refreshAllElimCells();
        }

        function refreshAllElimCells() {
            for(let i=1; i<=43; i++) {
                const th = document.getElementById('th-'+i);
                if (window.eliminatedNumbers.includes(i)) {
                    if(th) th.classList.add('eliminated-header');
                } else {
                    if(th) th.classList.remove('eliminated-header');
                }
            }
            document.getElementById('elimText').innerText = `蜑企勁蟇ｾ雎｡: [ ${window.eliminatedNumbers.sort((a,b)=>a-b).join(", ")} ]`;
            document.getElementById('elimText').style.display = 'block';
            if (window.currentPrediction && window.currentPrediction.length === 6) {
                renderPredictionOnHeader(window.currentPrediction);
            }
        }

        function renderPredictionOnHeader(selection) {
            for(let i=1; i<=43; i++) {
                const inner = document.getElementById('hnum-'+i);
                if (!inner) continue;
                
                // 繧ｯ繝ｩ繧ｹ繧剃ｸ譌ｦ繝ｪ繧ｻ繝・ヨ
                inner.className = 'header-num';
                
                if (selection.includes(i)) {
                    inner.classList.add(`col-${i%10}`);
                }
            }
        }

        function generatePrediction() {

            const minS = parseInt(document.getElementById('minSumInput').value) || 60;
            const maxS = parseInt(document.getElementById('maxSumInput').value) || 200;
            const oddsT = document.getElementById('oddsInput').value !== "" ? parseInt(document.getElementById('oddsInput').value) : null;
            const consecutiveT = document.getElementById('consecutiveInput').value !== "" ? parseInt(document.getElementById('consecutiveInput').value) : null;
            const lastDigitT = document.getElementById('lastDigitInput').value !== "" ? parseInt(document.getElementById('lastDigitInput').value) : null;
            let fixed = [];
            for(let i=1; i<=5; i++) { let v = document.getElementById('f'+i).value; if(v) fixed.push(parseInt(v)); }
            
            let scores = Array(44).fill(1);
            lotoData.slice(0, 50).forEach(d => d.numbers.forEach(n => scores[n] += 2));
            if(window.riverRocks.length) window.riverRocks.forEach(n => scores[n] += 15);

            // セット球推奨数字の選定と反映
            window.currentSetBallRecs = [];
            const selectedBall = document.getElementById('setBallSelect').value;
            if (selectedBall) {
                const top5 = getSetDynamicStats(selectedBall);
                if (top5.length > 0) {
                    let maxRecs = (fixed.length >= 5) ? 1 : 2;
                    let recs = top5.slice(0, maxRecs).map(t => t.n);
                    window.currentSetBallRecs = recs;
                    recs.forEach(rn => {
                        if (!fixed.includes(rn)) {
                            scores[rn] += 50; 
                        }
                    });
                }
            }

            let best = [];
            for (let t=0; t<8000; t++) {
                let avail = Array.from({length:43}, (_,i)=>i+1).filter(n => !window.eliminatedNumbers.includes(n) && !fixed.includes(n));
                let res = [...fixed];
                while(res.length < 6) {
                    let curS = res.reduce((a,b)=>a+b, 0), rem = 6-res.length;
                    let cands = avail.filter(n => (curS+n+(rem-1)*1 <= maxS) && (curS+n+(rem-1)*43 >= minS));
                    if(!cands.length) break;
                    let ts = cands.reduce((acc,n)=>acc+scores[n], 0);
                    let r = Math.random()*ts, p = cands[0];
                    for(let n of cands) { r -= scores[n]; if(r<=0) { p=n; break; } }
                    res.push(p); avail = avail.filter(x => x!==p);
                }
                if(res.length===6) {
                    res.sort((a,b)=>a-b);
                    let s = res.reduce((a,b)=>a+b, 0);
                    let o = res.filter(n=>n%2!==0).length;
                    
                    let cGroups = 0;
                    let inGroup = false;
                    for(let i=0; i<res.length-1; i++) {
                        if(res[i+1] - res[i] === 1) {
                            if(!inGroup) { cGroups++; inGroup = true; }
                        } else { inGroup = false; }
                    }

                    let dCounts = {};
                    res.forEach(n => { let d = n % 10; dCounts[d] = (dCounts[d] || 0) + 1; });
                    let ldGroups = Object.values(dCounts).filter(v => v > 1).length;

                    if(s>=minS && s<=maxS && 
                       (oddsT===null || o===oddsT) && 
                       (consecutiveT===null || cGroups===consecutiveT) &&
                       (lastDigitT===null || ldGroups===lastDigitT)) { 
                        best = res; break; 
                    }
                }
            }
            if(best.length===6) {
                window.currentPrediction = best;
                renderPredictionOnHeader(best);
                savePrediction(best);
                
                let odds = best.filter(x => x % 2 !== 0).length;
                let evens = 6 - odds;
                let sum = best.reduce((a,b)=>a+b, 0);
                let low = best.filter(x => x <= 21).length;
                let high = 6 - low;
                
                let theTxt = window.riverMode ? `<li><strong style="color:#e65100;">🌊 数字の川理論を適用</strong>: 出現確率の高い「連番」、「末尾一致」、および「引っ張りの岩（前回の当選数字）」の条件で構成。</li>` : "";
                let elimTxt = window.eliminatedNumbers.length > 0 ? `<li><strong>削除数字の連携</strong>: ${window.eliminatedNumbers.length}個の削除数字（表ヘッダの✖印）を回避しました。</li>` : "";
                let oddsTxtInfo = (oddsT !== null) ? `（ユーザー指定 ${oddsT}:${6-oddsT}）` : `（バランス重視）`;
                let fixedTxtInfo = fixed.length > 0 ? `<li><strong>固定数字の設定</strong>: 指定された ${fixed.length}個の数字（${fixed.join(", ")}）を確実に含めています。</li>` : "";

                let setBallReasonTxt = "";
                const ball = document.getElementById('setBallSelect').value;
                if (ball) {
                    const top5 = getSetDynamicStats(ball);
                    if (top5.length > 0) {
                        const recs = window.currentSetBallRecs || [];
                        const recNumsStr = recs.map(n => `[${n}]`).join("と");
                        let reason = "";
                        if (recs.length === 2) {
                            reason = `直近50回の${ball}セットで出現回数が上位（${top5[0].c}回〜）であり、現在の出現サイクルにおいて非常に高いポテンシャルを持っているため選出しました。`;
                        } else if (recs.length === 1) {
                            reason = `直近50回の${ball}セットにおいて最多出現（${top5[0].c}回）を記録しており、強力な軸として期待できるため選出しました。`;
                        }
                        let priorityNote = (recs.length < 2 && top5.length >= 2 && fixed.length >= 5) ? 
                            "<br><span style='color:#ef4444; font-size:11px;'>※ユーザー指定の固定数字を優先したため、セット球推奨数字を一部調整しました。</span>" : "";
                        setBallReasonTxt = `<li><strong>セット球 ${ball}の選択</strong>: ${recNumsStr}を選出 (${reason})${priorityNote}</li>`;
                    }
                }

                const pText = document.getElementById('predictText');
                pText.innerHTML = `<strong>【予測ロジック解説】</strong><br>
                    <ul style="margin: 8px 0; padding-left: 20px;">
                        ${theTxt}
                        ${elimTxt}
                        ${fixedTxtInfo}
                        ${setBallReasonTxt}
                        <li><strong>バランス調整（奇数偶数・高低）</strong>：奇数 <b>${odds}</b> : 偶数 <b>${evens}</b> ${oddsTxtInfo}、低い数字(1-21) <b>${low}</b> : 高い数字(22-43) <b>${high}</b> のバランスで構成。</li>
                        <li><strong>合計値の最適化</strong>：合計値 <b>${sum}</b>（指定範囲 ${minS}〜${maxS}）の条件を満たす組み合わせを抽出。</li>
                        <li><strong>当せん金最大化の戦略</strong>：誕生日目当ての構成（1〜31だけ）などによる当せん金の目減りを防ぐため、32以上の数字が選ばれるよう調整されています。</li>
                    </ul>
                    <div class="prediction-result-display">
                        ${best.map(n => `<div class="result-ball col-${n%10}">${n < 10 ? '0'+n : n}</div>`).join("")}
                    </div>`;
                pText.style.display = 'block';

            } else { 
                let msg = `条件に合う組み合わせが8000回の試行内で見つかりませんでした。\n以下の条件が厳しすぎる、もしくは互いに矛盾している可能性があります：\n`;
                msg += `・合計値: ${minS}〜${maxS}\n`;
                if(oddsT !== null) msg += `・奇数比率: ${oddsT}\n`;
                if(consecutiveT !== null) msg += `・連番数: ${consecutiveT}組\n`;
                if(lastDigitT !== null) msg += `・下一桁同数: ${lastDigitT}組\n`;
                if(fixed.length > 0) msg += `・固定数字: ${fixed.join(",")}\n`;
                msg += `\n【対策】\n・各プルダウンを「設定なし」に戻す\n・合計値の範囲を広げる\n・固定数字を少なくする\nなど、条件を緩めて再度お試しください。`;
                alert(msg); 
            }
        }
        function savePrediction(nums) {
            let h = JSON.parse(localStorage.getItem('loto6_history') || "[]");
            h.unshift({ nums, date: new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}), targetDraw: parseInt(lotoData[0].id.replace(/[^0-9]/g, ""))+1 });
            if(h.length > 5) h.pop();
            localStorage.setItem('loto6_history', JSON.stringify(h));
            renderHistory();
        }

        function renderHistory() {
            const h = JSON.parse(localStorage.getItem('loto6_history') || "[]");
            document.getElementById('predictionHistory').innerHTML = h.map(item => `
                <div style="background:#f8fafc; padding:10px; border-radius:6px; margin-bottom:8px; border-left:3px solid var(--accent-blue); border: 1px solid #e2e8f0; font-size:12px;">
                    <div style="color:#64748b; margin-bottom: 2px;">第${item.targetDraw}回 ${item.date}</div>
                    <div style="font-weight:700; color:var(--text-dark);">${item.nums.join(", ")}</div>
                </div>
            `).join("");
        }


        function initSetBall() {
            const balls = ['A','B','C','D','E','F','G','H','I','J'];
            let gaps = {}; balls.forEach(b => gaps[b] = 999);
            lotoData.forEach((d, i) => { if(balls.includes(d.set_ball) && gaps[d.set_ball] === 999) gaps[d.set_ball] = i; });
            let cand = 'A', maxG = -1;
            balls.forEach(b => { if(gaps[b] > maxG) { maxG = gaps[b]; cand = b; } });
            document.getElementById('predictedSetBallSpan').innerText = `💡 予測セット球: ${cand} (推奨理由: 過去${maxG}回出現なし)`;
        }

        function toggleRiverTheory() {
            window.riverMode = !window.riverMode;
            const btn = document.getElementById('btnRiver');
            btn.classList.toggle('active', window.riverMode);
            if(window.riverMode) {
                const rocks = lotoData[0].numbers.filter(n => lotoData[1].numbers.includes(n));
                window.riverRocks = rocks.length ? rocks : [lotoData[0].numbers[0]];
                document.getElementById('riverText').innerHTML = `🌊 <b>川理論 適用中:</b><br><span style="font-size:12px; color:#555;">過去の連続性を分析し予測スコアを強化しています。今回の「引っ張りの岩（前回当選数字に基づく軸）」は <b>[ ${window.riverRocks.join(", ")} ]</b> であり、これらを引数として関連数字の出現確率を大幅に引き上げました。</span>`;
                document.getElementById('riverText').style.display = 'block';
            } else {
                window.riverRocks = [];
                document.getElementById('riverText').style.display = 'none';
            }
        }

        function calculateEliminations() {
            let seen = Array(44).fill(999);
            lotoData.forEach((d, i) => d.numbers.forEach(n => { if(seen[n]===999) seen[n]=i; }));
            let cold = []; for(let i=1; i<=43; i++) cold.push({n:i, s:seen[i]});
            cold.sort((a,b)=>b.s-a.s);
            window.eliminatedNumbers = [cold[0].n, cold[1].n];
            refreshAllElimCells();
        }
        function updateStats() {
            let v = parseInt(localStorage.getItem('v_c') || "1240") + 1;
            localStorage.setItem('v_c', v);
            document.getElementById('statVisitors').innerText = v.toLocaleString();
            document.getElementById('statViewing').innerText = 40 + Math.floor(Math.random()*20);
            renderHistory();
        }

        function updateEvens() {
            const o = document.getElementById("oddsInput").value;
            document.getElementById("evensDisplay").innerText = o !== "" ? 6 - parseInt(o) : "-";
        }

        function toggleSidebar() {
            const sb = document.getElementById('sidebar');
            sb.classList.toggle('hidden');
        }

        function getSetDynamicStats(ball) {
            const recent50 = lotoData.slice(0, 50);
            const ballDraws = recent50.filter(d => d.set_ball === ball);
            if (ballDraws.length === 0) return [];
            
            const counts = {};
            ballDraws.forEach(d => {
                d.numbers.forEach(n => counts[n] = (counts[n] || 0) + 1);
            });
            
            return Object.entries(counts)
                .map(([n, c]) => ({ n: parseInt(n), c }))
                .sort((a,b) => b.c - a.c || a.n - b.n)
                .slice(0, 5);
        }


        function onSetBallChange() {
            const ball = document.getElementById('setBallSelect').value;
            const span = document.getElementById('predictedSetBallSpan');
            if(!ball) {
                initSetBall();
                return;
            }
            const tops = getSetDynamicStats(ball);
            if(tops.length === 0) {
                span.innerHTML = `⚠️ 直近50回において${ball}セットの出現はありません。`;
                return;
            }
            let topStr = tops.map(t => `<strong style="color:var(--accent-blue);">[${t.n}]</strong> ${t.c}回`).join(" / ");
            span.innerHTML = `🏆 <b>${ball}セット ベスト5 (直近50回):</b> <span style="margin-left:5px;">${topStr}</span>`;
        }

        function resetConditions() {
            document.getElementById('minSumInput').value = 60;
            document.getElementById('maxSumInput').value = 200;
            document.getElementById('oddsInput').value = "";
            updateEvens();
            for(let i=1;i<=5;i++) document.getElementById('f'+i).value = "";
            document.getElementById('setBallSelect').value = "";
            document.getElementById('consecutiveInput').value = "";
            document.getElementById('lastDigitInput').value = "";
            document.querySelector('input[name="elim_mode"][value="auto"]').checked = true;
            window.eliminatedNumbers = [];
            refreshAllElimCells();
            document.getElementById('predictText').style.display = 'none';
            document.getElementById('riverText').style.display = 'none';
            window.riverMode = false;
            document.getElementById('btnRiver').classList.remove('active');
            onSetBallChange();
            renderPredictionOnHeader([]);
        }

        function renderLatestTrends() {
            if (!lotoData || lotoData.length === 0) return;
            const latest = lotoData[0];
            const targetNumbers = [...latest.numbers];
            if (latest.bonus) targetNumbers.push(latest.bonus);

            // Calculate all TOP5s to find duplicates
            let allFreqs = [];
            targetNumbers.forEach(n => {
                let counts = Array(44).fill(0);
                let totalEvents = 0;
                for(let i = 1; i < lotoData.length; i++) {
                    let draw = lotoData[i];
                    let nextDraw = lotoData[i-1];
                    if (draw.numbers.includes(n) || draw.bonus === n) {
                        totalEvents++;
                        nextDraw.numbers.forEach(nxt => { counts[nxt]++; });
                    }
                }
                let freqs = [];
                for(let i=1; i<=43; i++) {
                    if(counts[i] > 0) freqs.push({num: i, c: counts[i], pct: (counts[i]/totalEvents*100).toFixed(1)});
                }
                freqs.sort((a,b) => b.c - a.c);
                allFreqs.push({ target: n, top5: freqs.slice(0,5) });
            });

            // Identify overlapping numbers
            let top5Counts = {};
            allFreqs.forEach(f => {
                f.top5.forEach(t => top5Counts[t.num] = (top5Counts[t.num] || 0) + 1);
            });

            // Assign colors
            const palette = ['#ec4899', '#3b82f6', '#10b981', '#ef4444', '#8b5cf6', '#d946ef', '#0ea5e9', '#84cc16'];
            let colorMap = {};
            let cIndex = 0;
            for(const [num, count] of Object.entries(top5Counts)) {
                if(count >= 2) {
                    colorMap[num] = palette[cIndex % palette.length];
                    cIndex++;
                }
            }

            let html = `<strong style="font-size: 14px;">【最新回（${latest.id}）からの次出現傾向：各数字の次に出た数字 TOP5】</strong><br>
                        <div style="font-size:11px; color:#666; margin-top:2px;">※今回複数の数字から重複してTOP5にランクインした有望数字は、同色マーカーで強調しています。</div>
                        <div style="display:flex; flex-wrap:wrap; gap: 8px 15px; margin-top: 8px;">`;

            allFreqs.forEach(f => {
                let n = f.target;
                let isBonus = (n === latest.bonus);
                
                let topStr = f.top5.map(t => {
                    let style = `color:var(--accent-blue); font-weight:bold;`;
                    if(colorMap[t.num]) {
                       style = `background:${colorMap[t.num]}; color:#fff; border-radius:3px; padding:0 3px; font-weight:bold;`;
                    }
                    return `<span style="${style}">[${t.num}]</span> ${t.pct}%`;
                }).join(" / ");
                
                let label = isBonus ? `繝・{n}` : `${n}`;
                let numColor = isBonus ? "#d97706" : "#1e293b";
                let bgBadge = isBonus ? "#fef3c7" : "#e2e8f0";
                
                html += `<div style="flex-basis: 48%; min-width: 320px; display:flex; align-items:center;">
                            <span style="display:inline-block; width: 64px; text-align:center; background:${bgBadge}; color:${numColor}; border-radius:4px; padding:2px 0; font-weight:bold; margin-right:8px;">${label} 縺ｮ蠕・/span> 
                            <span style="font-size: 12px; color:#5c4d04;">${topStr}</span>
                         </div>`;
            });
            
            html += `</div>`;
            document.getElementById('latestTrendBox').innerHTML = html;
        }

        renderLatestTrends();
        renderBoard();

        // --- Firebase 繝ｪ繧｢繝ｫ繧ｿ繧､繝邨ｱ險・邨ｱ蜷・---
        let currentPredListener = null;

        const fbConfig = {
            apiKey: "AIzaSyB850G38tHq6-00374025556209",
            authDomain: "loto6-analytics.firebaseapp.com",
            databaseURL: "https://loto6-analytics-default-rtdb.firebaseio.com",
            projectId: "loto6-analytics",
            storageBucket: "loto6-analytics.appspot.com",
            messagingSenderId: "374025556209",
            appId: "1:374025556209:web:9f8e4e9f73f84f009028",
            measurementId: "G-LBFJ3ZXFNE"
        };

        const loadFirebase = async () => {
            const { initializeApp } = await import("https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js");
            const { getDatabase, ref, onValue, set, off, onDisconnect, serverTimestamp, runTransaction } = await import("https://www.gstatic.com/firebasejs/10.8.0/firebase-database.js");

            const app = initializeApp(fbConfig);
            const db = getDatabase(app);
            const sessionId = Math.random().toString(36).substring(7);

            // 1. 迴ｾ蝨ｨ髢ｲ隕ｧ荳ｭ (Presence) - 繝ｪ繧｢繝ｫ繧ｿ繧､繝譖ｴ譁ｰ
            const myStatusRef = ref(db, `presence/${sessionId}`);
            const connectedRef = ref(db, ".info/connected");

            onValue(connectedRef, (snap) => {
                if (snap.val() === true) {
                    onDisconnect(myStatusRef).remove();
                    set(myStatusRef, serverTimestamp());
                }
            });

            onValue(ref(db, "presence"), (snap) => {
                const count = snap.exists() ? Object.keys(snap.val()).length : 1;
                document.getElementById('statViewing').innerText = count;
            });

            // 2. 譛ｬ譌･縺ｮ繧｢繧ｯ繧ｻ繧ｹ謨ｰ (邏ｯ險・ - 豈取律 0:00 譖ｴ譁ｰ
            const updateVisitorCount = () => {
                const todayStr = new Date().toISOString().split('T')[0];
                const visitorRef = ref(db, `stats/${todayStr}/visitors`);
                
                if(!sessionStorage.getItem('loto6_visited')) {
                    runTransaction(visitorRef, (current) => (current || 0) + 1);
                    sessionStorage.setItem('loto6_visited', 'true');
                }
                
                onValue(visitorRef, (snap) => {
                    document.getElementById('statVisitors').innerText = snap.val() || 1;
                });
            };
            updateVisitorCount();

            // 3. 谺｡蝗槭∪縺ｧ縺ｮ邱丈ｺ域Φ螳溯｡梧焚 - 謚ｽ驕ｸ譌･ 18:20 譖ｴ譁ｰ
            window.setupPredictionCounter = () => {
                if (currentPredListener) off(currentPredListener);

                const nextId = parseInt(lotoData[0].id.replace(/[^0-9]/g, "")) + 1;
                const predPath = `stats/predictions/draw_${nextId}`;
                const predRef = ref(db, predPath);

                currentPredListener = onValue(predRef, (snap) => {
                    document.getElementById('statPredictions').innerText = snap.val() || 0;
                });

                // 螳溯｡梧焚繧貞｢励ｄ縺吶げ繝ｭ繝ｼ繝舌Ν髢｢謨ｰ
                window.incrementPredictionCount = () => {
                    runTransaction(predRef, (current) => (current || 0) + 1);
                };
            };
            window.setupPredictionCounter();
        };
        loadFirebase().catch(console.error);

        // 莠域Φ繝ｻ讀懃ｴ｢螻･豁ｴ縺ｮ邂｡逅・
        function savePrediction(nums) {
            let h = JSON.parse(localStorage.getItem('loto6_history') || "[]");
            const today = new Date();
            const timeStr = today.getFullYear() + "/" + (today.getMonth()+1) + "/" + today.getDate() + " " + today.getHours().toString().padStart(2, '0') + ":" + today.getMinutes().toString().padStart(2, '0');
            
            // 蜈ｨ縺ｦ縺ｮ讀懃ｴ｢譚｡莉ｶ繧貞叙蠕・
            const fixedNums = [
                document.getElementById('f1').value,
                document.getElementById('f2').value,
                document.getElementById('f3').value,
                document.getElementById('f4').value,
                document.getElementById('f5').value
            ].filter(v => v !== "").join(",");

            const conditions = {
                sum: document.getElementById('minSumInput').value + "縲・ + document.getElementById('maxSumInput').value,
                odds: document.getElementById('oddsInput').value || "莉ｻ諢・,
                set: document.getElementById('setBallSelect').value || "莉ｻ諢・,
                consecutive: document.getElementById('consecutiveInput').value || "莉ｻ諢・,
                lastDigit: document.getElementById('lastDigitInput').value || "莉ｻ諢・,
                fixed: fixedNums || "縺ｪ縺・,
                river: window.riverMode ? "ON" : "OFF",
                elimCount: window.eliminatedNumbers.length || 0
            };

            const nextId = parseInt(lotoData[0].id.replace(/[^0-9]/g, ""))+1;

            h.unshift({ 
                nums, 
                time: timeStr, 
                draw: nextId,
                conditions
            });

            // 100莉ｶ縺ｫ蛻ｶ髯・
            if(h.length > 100) h.pop();
            localStorage.setItem('loto6_history', JSON.stringify(h));
            
            // Firebase縺ｮ螳溯｡梧焚繧よ峩譁ｰ
            if(window.incrementPredictionCount) {
                window.incrementPredictionCount();
            }
            // Firebase縺ｫ莠域ｸｬ邨先棡繧帝∽ｿ｡ (繧ｵ繧､繝亥・菴薙・邨ｱ險育畑)
            if(window.pushGlobalPrediction) {
                window.pushGlobalPrediction(nextId, nums);
            }

            renderHistory();
        }

        function renderHistory() {
            const h = JSON.parse(localStorage.getItem('loto6_history') || "[]");
            const sideContainer = document.getElementById('predictionHistory');
            
            // 1. 繧ｵ繧､繝峨ヰ繝ｼ謠冗判 (譛譁ｰ5莉ｶ)
            const sideItems = h.slice(0, 5);
            if(sideItems.length === 0) {
                sideContainer.innerHTML = '<div style="font-size:13px; color:#94a3b8; text-align:center; padding:15px;">螻･豁ｴ縺ｯ縺ゅｊ縺ｾ縺帙ｓ</div>';
            } else {
                sideContainer.innerHTML = sideItems.map(item => `
                    <div style="background:#f8fafc; padding:10px; border-radius:8px; margin-bottom:10px; border: 1px solid #e2e8f0; font-size:13px;">
                        <div style="color:#64748b; margin-bottom: 6px; font-weight: 600;">隨ｬ${item.draw}蝗・${item.time.split(" ")[1]}</div>
                        <div style="display:flex; gap:5px; justify-content:center;">
                            ${item.nums.map(n => `<span style="width:24px; height:24px; border-radius:50%; background:#334155; color:#fff; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:700;">${n}</span>`).join("")}
                        </div>
                    </div>
                `).join("");
                sideContainer.querySelectorAll('span').forEach(s => {
                    const n = parseInt(s.innerText);
                    const colors = ["#828282", "#1a9c2a", "#00d0e0", "#f79c11", "#8c8c11", "#11d911", "#fce803", "#881c88", "#198080", "#1133e6"];
                    s.style.backgroundColor = colors[n%10];
                    if(n%10 === 6) s.style.color = "#000";
                });
            }
        }

        // --- History Modal & Ticket Image Logic ---
        function openHistoryModal() {
            document.getElementById('historyModal').style.display = 'flex';
            renderHistoryModal();
        }

        function closeHistoryModal() {
            document.getElementById('historyModal').style.display = 'none';
        }

        function renderHistoryModal() {
            const h = JSON.parse(localStorage.getItem('loto6_history') || "[]");
            const tbody = document.getElementById('historyModalTableBody');
            
            // 邂｡逅・判髱｢縺九ｉ隲也炊蜑企勁・磯撼陦ｨ遉ｺ・峨＆繧後◆繧ゅ・繧帝勁螟悶＠縺ｦ陦ｨ遉ｺ
            const visibleItems = h.map((item, originalIdx) => ({...item, originalIdx}))
                                  .filter(item => !item.deletedFromModal);
            
            if(visibleItems.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" style="padding:40px; color:#94a3b8;">螻･豁ｴ縺後≠繧翫∪縺帙ｓ</td></tr>';
                return;
            }

            tbody.innerHTML = visibleItems.map((item) => `
                <tr>
                    <td><input type="checkbox" class="history-check" data-index="${item.originalIdx}"></td>
                    <td style="font-size:11px; white-space:nowrap;">${item.time}</td>
                    <td>隨ｬ${item.draw}蝗・/td>
                    <td>
                        <div style="display:flex; gap:4px; justify-content:center;">
                            ${item.nums.map(n => {
                                const colors = ["#828282", "#1a9c2a", "#00d0e0", "#f79c11", "#8c8c11", "#11d911", "#fce803", "#881c88", "#198080", "#1133e6"];
                                return `<span style="width:20px; height:20px; border-radius:50%; background:${colors[n%10]}; color:${n%10===6?'#000':'#fff'}; display:flex; align-items:center; justify-content:center; font-size:10px; font-weight:bold;">${n}</span>`;
                            }).join("")}
                        </div>
                    </td>
                </tr>
            `).join("");
        }

        function deleteSelectedHistory() {
            const checks = document.querySelectorAll('.history-check:checked');
            if(checks.length === 0) {
                alert("蜑企勁縺吶ｋ鬆・岼繧帝∈謚槭＠縺ｦ縺上□縺輔＞縲・);
                return;
            }
            if(!confirm("驕ｸ謚槭＠縺滄・岼繧貞炎髯､縺励∪縺吶°・・)) return;

            let h = JSON.parse(localStorage.getItem('loto6_history') || "[]");
            const indicesToDelete = Array.from(checks).map(c => parseInt(c.dataset.index)).sort((a,b) => b - a);
            
            indicesToDelete.forEach(idx => h.splice(idx, 1));
            localStorage.setItem('loto6_history', JSON.stringify(h));
            
            renderHistoryModal();
            renderHistory();
        }

        function toggleLatestTrend() {
            const content = document.getElementById('latestTrendBox');
            const icon = document.getElementById('trendToggleIcon');
            if (content.style.display === 'none') {
                content.style.display = 'block';
                icon.innerText = '笆ｲ';
            } else {
                content.style.display = 'none';
                icon.innerText = '笆ｼ';
            }
        }

        function clearAllHistory() {
            let h = JSON.parse(localStorage.getItem('loto6_history') || "[]");
            // 迚ｩ逅・炎髯､縺帙★縲∫ｮ｡逅・判髱｢荳翫〒縺ｮ髱櫁｡ｨ遉ｺ繝輔Λ繧ｰ繧堤ｫ九※繧具ｼ医し繧､繝峨ヰ繝ｼ蜈ｱ譛牙・繧剃ｿ晁ｭｷ・・
            h = h.map(item => ({ ...item, deletedFromModal: true }));
            localStorage.setItem('loto6_history', JSON.stringify(h));
            renderHistoryModal();
            renderHistory();
        }

        async function generateTicketImage() {
            const checks = document.querySelectorAll('.history-check:checked');
            if(checks.length === 0) {
                alert("逕ｻ蜒上↓蜷ｫ繧√ｋ鬆・岼繧帝∈謚槭＠縺ｦ縺上□縺輔＞・域怙螟ｧ5縺､・峨・);
                return;
            }
            if(checks.length > 5) {
                alert("荳蠎ｦ縺ｫ蜃ｺ蜉帙〒縺阪ｋ縺ｮ縺ｯ譛螟ｧ5莉ｶ縺ｾ縺ｧ縺ｧ縺吶・);
                return;
            }

            const h = JSON.parse(localStorage.getItem('loto6_history') || "[]");
            const selected = Array.from(checks).map(c => h[parseInt(c.dataset.index)]);
            
            // 繝・Φ繝励Ξ繝ｼ繝医↓繝・・繧ｿ繧呈ｵ√＠霎ｼ繧
            const drawId = selected[0].draw;
            document.getElementById('t-subtitle').innerText = `隨ｬ${drawId}蝗・繝ｭ繝・6 謚ｽ縺帙ｓ蛻ｸ`;
            
            // 謚ｽ縺帙ｓ譌･縺ｮ謗ｨ螳・(譛医・譛ｨ)
            // 騾壼ｸｸ縲∵怙譁ｰ縺ｮ蝗槫挨縺ｮ谺｡縺ｮ蝗槫挨縺ｪ繧画悴譚･縺ｮ譌･莉・
            const drawDate = getEstimateDrawDate(drawId);
            document.getElementById('t-drawDate').innerText = drawDate.toLocaleDateString('ja-JP');
            
            // 謾ｯ謇墓悄髯・(3繝ｶ譛亥ｾ・
            const deadline = new Date(drawDate);
            deadline.setMonth(deadline.getMonth() + 3);
            document.getElementById('t-deadline').innerText = deadline.toLocaleDateString('ja-JP');
            
            // 雉ｼ蜈･譌･譎・
            const now = new Date();
            document.getElementById('t-buyDate').innerText = `${now.toLocaleDateString('ja-JP')} ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
            
            document.getElementById('t-amount').innerText = selected.length * 200;
            
            // 繝代ち繝ｼ繝ｳ A縲廢
            const pContainer = document.getElementById('t-patterns');
            const labels = ["A", "B", "C", "D", "E"];
            pContainer.innerHTML = selected.map((item, idx) => `
                <div class="pattern-row">
                    <div class="pattern-label">${labels[idx]}</div>
                    <div class="pattern-nums">
                        ${item.nums.map(n => String(n).padStart(2, '0')).join("&nbsp;&nbsp;")}
                    </div>
                </div>
            `).join("");

            // 繧ｭ繝｣繝励メ繝｣
            const template = document.getElementById('ticket-template');
            try {
                const canvas = await html2canvas(template, {
                    scale: 2,
                    backgroundColor: "#ffffff",
                    logging: false
                });
                const link = document.createElement('a');
                link.download = `loto6_ticket_${drawId}_${new Date().getTime()}.png`;
                link.href = canvas.toDataURL();
                link.click();
            } catch (e) {
                console.error("Capture failed", e);
                alert("逕ｻ蜒上・逕滓・縺ｫ螟ｱ謨励＠縺ｾ縺励◆縲・);
            }
        }

        function getEstimateDrawDate(drawId) {
            // lotoData[0] 縺梧怙譁ｰ蝗・
            const latest = lotoData[0];
            const latestId = parseInt(latest.id.replace(/[^0-9]/g, ""));
            const latestDate = new Date(latest.date);
            
            if (drawId === latestId) return latestDate;
            
            // 繧ｷ繝ｳ繝励Ν縺ｫ drawId 縺ｮ蟾ｮ蛻・°繧画怦繝ｻ譛ｨ繧呈耳貂ｬ縺励※騾ｲ繧√ｋ
            let targetDate = new Date(latestDate);
            let currentId = latestId;
            const diff = drawId - latestId;
            
            if (diff > 0) {
                for(let i=0; i<diff; i++) {
                    // 谺｡縺ｮ譛医°譛ｨ繧呈爾縺・
                    do {
                        targetDate.setDate(targetDate.getDate() + 1);
                    } while (targetDate.getDay() !== 1 && targetDate.getDay() !== 4);
                }
            } else if (diff < 0) {
                for(let i=0; i<Math.abs(diff); i++) {
                    do {
                        targetDate.setDate(targetDate.getDate() - 1);
                    } while (targetDate.getDay() !== 1 && targetDate.getDay() !== 4);
                }
            }
            return targetDate;
        }

        // --- 18:20 繧ｿ繧､繝繝ｭ繧ｸ繝・け ---
        function checkDrawTiming() {
            const now = new Date();
            const day = now.getDay(); // 1:Mon, 4:Thu
            const hour = now.getHours();
            const min = now.getMinutes();
            
            // 譛医・譛ｨ 縺ｮ 18:20 縺ｫ繝ｪ繧ｻ繝・ヨ蜃ｦ逅・
            if ((day === 1 || day === 4) && hour === 18 && min === 20) {
                if (!window.hasResetToday) {
                    performDrawReset();
                    window.hasResetToday = true;
                }
            } else {
                window.hasResetToday = false;
            }
        }

        function performDrawReset() {
            console.log("Draw reset triggered at 18:20");
            
            // 1. 谺｡蝗槫屓謨ｰ繧偵う繝ｳ繧ｯ繝ｪ繝｡繝ｳ繝茨ｼ郁｡ｨ遉ｺ逕ｨ・・
            const nextRound = parseInt(lotoData[0].id.replace(/[^0-9]/g, "")) + 1;
            document.getElementById('latestRoundInfo').innerText = `隨ｬ${nextRound}蝗・莠域Φ蜿嶺ｻ倅ｸｭ`;
            
            // 2. 繧ｵ繧､繝峨ヰ繝ｼ螻･豁ｴ蜑企勁
            const sideContainer = document.getElementById('predictionHistory');
            sideContainer.innerHTML = '<div style="font-size:13px; color:#94a3b8; text-align:center; padding:15px;">繝ｪ繧ｻ繝・ヨ縺輔ｌ縺ｾ縺励◆</div>';
            
            // 3. 谺｡謨ｰ縺ｾ縺ｧ縺ｮ螳溯｡梧焚繝ｪ繧ｻ繝・ヨ・域ｬ｡蝗槫屓蜿ｷ縺ｸ縺ｮ蛻・ｊ譖ｿ縺茨ｼ・
            if(window.setupPredictionCounter) {
                window.setupPredictionCounter();
            } else {
                document.getElementById('statPredictions').innerText = "0";
            }

            // 4. 譖ｴ譁ｰ蠕・■迥ｶ諷九∈
            document.getElementById('latestTrendBox').innerHTML = `<div style="text-align:center; color:#94a3b8; padding:10px;">隨ｬ${nextRound}蝗樒ｵ先棡譖ｴ譁ｰ蠕・■... (繝・・繧ｿ譖ｴ譁ｰ縺後≠繧九∪縺ｧ蜃ｺ迴ｾ蛯ｾ蜷代・譖ｴ譁ｰ縺輔ｌ縺ｾ縺帙ｓ)</div>`;
            document.getElementById('latestNumbersDisplay').innerHTML = "";
            document.getElementById('latestDrawDate').innerText = "譖ｴ譁ｰ蠕・■";
            document.getElementById('latestSetBallDisplay').innerText = "竚・;
            
            // 5. 繝ｭ繝ｼ繧ｫ繝ｫ繧ｹ繝医Ξ繝ｼ繧ｸ縺ｮ螻･豁ｴ繧よｶ亥悉・亥燕蝗槭・蝗槭・蛻・ｼ・
            // 蜈ｨ蜑企勁縺ｧ縺ｯ縺ｪ縺上し繧､繝峨ヰ繝ｼ縺ｮ縺ｿ蠖ｱ髻ｿ縺輔○繧九→縺ｮ縺薙→縺縺後√Θ繝ｼ繧ｶ繝ｼ縺ｮ謖・､ｺ縲・8:20蛻・↓縺ｪ縺｣縺滓凾轤ｹ縺ｧ2093蝗槫・縺ｮ繧ｵ繧､繝峨ヰ繝ｼ縺ｮ莠域Φ繝ｻ讀懃ｴ｢螻･豁ｴ縺ｯ蜑企勁縲阪↓蠕薙≧
            let h = JSON.parse(localStorage.getItem('loto6_history') || "[]");
            h = h.filter(item => item.draw > nextRound - 1); // 譁ｰ縺励＞蝗槭・蛻・□縺第ｮ九☆・磯壼ｸｸ縺ｯ遨ｺ縺ｫ縺ｪ繧具ｼ・
            localStorage.setItem('loto6_history', JSON.stringify(h));
            renderHistory();
        }

        setInterval(checkDrawTiming, 60000); // 1蛻・＃縺ｨ縺ｫ繝√ぉ繝・け
        checkDrawTiming(); // 蛻晄悄繝√ぉ繝・け
        renderHistory();

        // Firebase logic addition for pushing predictions
        const pushPredictionToFirebase = async (drawId, nums) => {
             // 繝ｦ繝ｼ繧ｶ繝ｼ縺ｮ蜈ｨ讀懃ｴ｢螻･豁ｴ繧巽irebase縺ｫ髮・ｴ・ｼ医し繧､繝峨ヰ繝ｼ縺ｮ蠖馴∈螳溽ｸｾ險育ｮ礼畑・・
             // 縺薙％縺ｧ縺ｯ Firebase DB 縺ｮ 'predictions/ALL' 縺ｫ霑ｽ蜉縺吶ｋ
             const { getDatabase, ref, push, serverTimestamp } = await import("https://www.gstatic.com/firebasejs/10.8.0/firebase-database.js");
             const db = getDatabase();
             push(ref(db, `site_predictions/${drawId}`), {
                 nums: nums,
                 timestamp: serverTimestamp()
             });
        };
        window.pushGlobalPrediction = pushPredictionToFirebase;

        renderHistory();

        function openPP() { document.getElementById('ppModal').style.display = 'flex'; }
        function closePP() { document.getElementById('ppModal').style.display = 'none'; }
        
        function openTerms() { document.getElementById('termsModal').style.display = 'flex'; }
        function closeTerms() { document.getElementById('termsModal').style.display = 'none'; }

        function openContact() { document.getElementById('contactModal').style.display = 'flex'; }
        function closeContact() { document.getElementById('contactModal').style.display = 'none'; }

        async function submitContactForm(event) {
            event.preventDefault();
            const btn = document.getElementById('btnSubmitContact');
            const status = document.getElementById('contactStatus');
            const originalText = btn.innerText;
            
            btn.disabled = true;
            btn.innerText = "騾∽ｿ｡荳ｭ...";
            status.style.display = 'none';

            const formData = new FormData(event.target);
            const data = Object.fromEntries(formData.entries());

            try {
                // GAS縺ｮURL縺梧悴險ｭ螳壹・蝣ｴ蜷医・譯亥・
                const gasUrl = "https://script.google.com/macros/s/AKfycbzyX-HMUqK5JrlWd5mlwc6ZURJ2ORvNlVORufdZr7aP_zdjPsHy9GIHAs-wKAgjrJdz/exec"; 
                if (gasUrl === "YOUR_GAS_WEBAPP_URL_HERE") {
                    console.log("Form data:", data);
                    // 繝・Δ逕ｨ縺ｮ蜍穂ｽ懶ｼ・AS譛ｪ險ｭ螳壽凾・・
                    setTimeout(() => {
                        alert("縺雁撫縺・粋繧上○繝輔か繝ｼ繝縺ｮ騾∽ｿ｡蜈茨ｼ・AS・峨′縺ｾ縺險ｭ螳壹＆繧後※縺・∪縺帙ｓ縲・n繝悶Λ繧ｦ繧ｶ縺ｮ繧ｳ繝ｳ繧ｽ繝ｼ繝ｫ縺ｫ蜀・ｮｹ繧貞・蜉帙＠縺ｾ縺励◆縲・);
                        btn.disabled = false;
                        btn.innerText = originalText;
                        event.target.reset();
                        closeContact();
                    }, 1000);
                    return;
                }

                const response = await fetch(gasUrl, {
                    method: 'POST',
                    mode: 'no-cors', // GAS WebApp 縺ｮ蛻ｶ邏・
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                status.innerText = "繝｡繝・そ繝ｼ繧ｸ繧帝∽ｿ｡縺励∪縺励◆縲ゅ≠繧翫′縺ｨ縺・＃縺悶＞縺ｾ縺励◆縲・;
                status.style.color = "#22c55e";
                status.style.display = 'block';
                event.target.reset();
                setTimeout(closeContact, 3000);
            } catch (err) {
                console.error(err);
                status.innerText = "騾∽ｿ｡縺ｫ螟ｱ謨励＠縺ｾ縺励◆縲よ凾髢薙ｒ縺翫＞縺ｦ蜀榊ｺｦ縺願ｩｦ縺励￥縺縺輔＞縲・;
                status.style.color = "#ef4444";
                status.style.display = 'block';
            } finally {
                btn.disabled = false;
                btn.innerText = originalText;
            }
        }

        window.onclick = function(event) {
            const ppModal = document.getElementById('ppModal');
            const historyModal = document.getElementById('historyModal');
            const termsModal = document.getElementById('termsModal');
            const contactModal = document.getElementById('contactModal');
            if (event.target == ppModal) { closePP(); }
            if (event.target == historyModal) { closeHistoryModal(); }
            if (event.target == termsModal) { closeTerms(); }
            if (event.target == contactModal) { closeContact(); }
        }
    </script>

    <!-- 繝励Λ繧､繝舌す繝ｼ繝昴Μ繧ｷ繝ｼ繝ｻ繝｢繝ｼ繝繝ｫ -->
    <div id="ppModal" class="pp-modal-overlay">
        <div class="pp-modal-content">
            <div class="pp-modal-header">
                <h2>繝励Λ繧､繝舌す繝ｼ繝昴Μ繧ｷ繝ｼ</h2>
                <button class="pp-close" onclick="closePP()">&times;</button>
            </div>
            <div class="pp-body">
                <p>蠖薙し繧､繝茨ｼ・OTO6 蛻・梵繝励Λ繝・ヨ繝輔か繝ｼ繝・峨・縲√Θ繝ｼ繧ｶ繝ｼ縺ｮ蛻ｩ萓ｿ諤ｧ蜷台ｸ翫♀繧医・繧ｵ繧､繝域隼蝟・・縺溘ａ縲√い繧ｯ繧ｻ繧ｹ隗｣譫舌ｄ繝ｪ繧｢繝ｫ繧ｿ繧､繝邨ｱ險域ｩ溯・繧剃ｽｿ逕ｨ縺励※縺・∪縺吶ゅ％繧後ｉ縺ｮ繝・・繧ｿ縺ｯ繧ｵ繧､繝医・豢ｻ豌励ｒ蜿ｯ隕門喧縺吶ｋ逶ｮ逧・〒縺ｮ縺ｿ菴ｿ逕ｨ縺輔ｌ縲∝倶ｺｺ繧堤音螳壹☆繧区ュ蝣ｱ縺ｯ蜿朱寔縺輔ｌ縺ｾ縺帙ｓ縲・/p>
                
                <p>繝ｪ繧｢繝ｫ繧ｿ繧､繝邨ｱ險茨ｼ磯夢隕ｧ閠・焚縲∫ｴｯ險医い繧ｯ繧ｻ繧ｹ謨ｰ遲会ｼ峨・ Firebase Realtime Database 繧帝壹§縺ｦ蜈ｨ繝ｦ繝ｼ繧ｶ繝ｼ髢薙〒蜷梧悄縺輔ｌ縺ｾ縺吶・/p>

                <h3>蜈崎ｲｬ莠矩・/h3>
                <p>蠖薙す繧ｹ繝・Β縺梧署萓帙☆繧九ョ繝ｼ繧ｿ縺翫ｈ縺ｳ莠域Φ諠・ｱ縺ｯ縲・℃蜴ｻ縺ｮ謚ｽ驕ｸ邨先棡縺ｫ蝓ｺ縺･縺・◆邨ｱ險育噪縺ｪ蜿ｯ隕門喧繧堤岼逧・→縺励※縺翫ｊ縲∫音螳壹・蠖馴∈繧剃ｿ晁ｨｼ縺吶ｋ繧ゅ・縺ｧ縺ｯ縺ゅｊ縺ｾ縺帙ｓ縲ょｽ薙し繧､繝医・諠・ｱ繧貞茜逕ｨ縺励◆縺薙→縺ｧ逕溘§縺溘＞縺九↑繧区錐螳ｳ縺ｫ縺､縺・※繧ゅ∝ｽ捺婿縺ｯ荳蛻・・雋ｬ莉ｻ繧定ｲ縺・°縺ｭ縺ｾ縺吶よ怙邨ら噪縺ｪ雉ｼ蜈･蛻､譁ｭ縺ｯ閾ｪ蟾ｱ雋ｬ莉ｻ縺ｧ縺企｡倥＞縺・◆縺励∪縺吶・/p>
            </div>
        </div>
    </div>

    <!-- 螻･豁ｴ邂｡逅・Δ繝ｼ繝繝ｫ -->
    <div id="historyModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h2>糖 讀懃ｴ｢螻･豁ｴ縺ｮ邂｡逅・(譛螟ｧ100莉ｶ)</h2>
                <button class="pp-close" onclick="closeHistoryModal()">&times;</button>
            </div>
            <div class="modal-body">
                <table class="history-list-table">
                    <thead>
                        <tr>
                            <th style="width: 40px;">驕ｸ謚・/th>
                            <th style="width: 100px;">譌･譎・/th>
                            <th style="width: 70px;">蝗槫挨</th>
                            <th>莠域ｸｬ謨ｰ蟄・/th>
                        </tr>
                    </thead>
                    <tbody id="historyModalTableBody">
                        <!-- JS縺ｧ謖ｿ蜈･ -->
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button class="btn-modal btn-delete-all" onclick="clearAllHistory()">櫨 蜈ｨ螻･豁ｴ繧剃ｸ諡ｬ蜑企勁</button>
                <button class="btn-modal btn-delete-selected" onclick="deleteSelectedHistory()">卵・・驕ｸ謚槭＠縺滄・岼繧貞炎髯､</button>
                <button class="btn-modal btn-ticket" onclick="generateTicketImage()">萄 驕ｸ謚樣・岼縺ｧ逕ｻ蜒丈ｽ懈・ (譛螟ｧ5縺､)</button>
            </div>
        </div>
    </div>

    <!-- 蛻ｩ逕ｨ隕冗ｴ・・繝｢繝ｼ繝繝ｫ -->
    <div id="termsModal" class="pp-modal-overlay">
        <div class="pp-modal-content">
            <div class="pp-modal-header">
                <h2>蛻ｩ逕ｨ隕冗ｴ・/h2>
                <button class="pp-close" onclick="closeTerms()">&times;</button>
            </div>
            <div class="pp-body">
                <p>縺薙・蛻ｩ逕ｨ隕冗ｴ・ｼ井ｻ･荳具ｼ後梧悽隕冗ｴ・阪→縺・＞縺ｾ縺吶ゑｼ峨・・鍬OTO6 PRO・井ｻ･荳具ｼ後悟ｽ馴°蝟ｶ縲阪→縺・＞縺ｾ縺吶ゑｼ峨′縺薙・繧ｦ繧ｧ繝悶し繧､繝医〒謠蝉ｾ帙☆繧九し繝ｼ繝薙せ・井ｻ･荳具ｼ後梧悽繧ｵ繝ｼ繝薙せ縲阪→縺・＞縺ｾ縺吶ゑｼ峨・蛻ｩ逕ｨ譚｡莉ｶ繧貞ｮ壹ａ繧九ｂ縺ｮ縺ｧ縺吶・/p>

                <h3>隨ｬ1譚｡・磯←逕ｨ・・/h3>
                <p>譛ｬ隕冗ｴ・・・後Θ繝ｼ繧ｶ繝ｼ縺ｨ蠖馴°蝟ｶ縺ｨ縺ｮ髢薙・譛ｬ繧ｵ繝ｼ繝薙せ縺ｮ蛻ｩ逕ｨ縺ｫ髢｢繧上ｋ蜈ｨ縺ｦ縺ｮ髢｢菫ゅ↓驕ｩ逕ｨ縺輔ｌ繧九ｂ縺ｮ縺ｨ縺励∪縺吶・/p>

                <h3>隨ｬ2譚｡・育ｦ∵ｭ｢莠矩・ｼ・/h3>
                <p>繝ｦ繝ｼ繧ｶ繝ｼ縺ｯ・梧悽繧ｵ繝ｼ繝薙せ縺ｮ蛻ｩ逕ｨ縺ｫ縺ゅ◆繧奇ｼ御ｻ･荳九・陦檎ぜ繧偵＠縺ｦ縺ｯ縺ｪ繧翫∪縺帙ｓ縲・br>
                繝ｻ豕穂ｻ､縺ｾ縺溘・蜈ｬ蠎剰憶菫励↓驕募渚縺吶ｋ陦檎ぜ<br>
                繝ｻ譛ｬ繧ｵ繝ｼ繝薙せ縺ｮ驕句霧繧貞ｦｨ螳ｳ縺吶ｋ縺翫◎繧後・縺ゅｋ陦檎ぜ<br>
                繝ｻ莉悶・繝ｦ繝ｼ繧ｶ繝ｼ縺ｫ髢｢縺吶ｋ蛟倶ｺｺ諠・ｱ遲峨ｒ蜿朱寔縺ｾ縺溘・闢・ｩ阪☆繧玖｡檎ぜ</p>

                <h3>隨ｬ3譚｡・亥・雋ｬ莠矩・ｼ・/h3>
                <p>蠖馴°蝟ｶ縺ｯ・梧悽繧ｵ繝ｼ繝薙せ縺ｫ髢｢縺励※・梧・遉ｺ逧・↓繧るｻ咏､ｺ逧・↓繧ゑｼ後◎縺ｮ螳牙・諤ｧ・梧ｭ｣遒ｺ諤ｧ・檎｢ｺ螳滓ｧ・梧怏逕ｨ諤ｧ・檎音螳壹・逶ｮ逧・∈縺ｮ驕ｩ蜷域ｧ・後さ繝ｳ繝斐Η繝ｼ繧ｿ繧ｦ繧｣繝ｫ繧ｹ遲峨′蜷ｫ縺ｾ繧後※縺・↑縺・％縺ｨ遲峨・菫晁ｨｼ繧定｡後≧繧ゅ・縺ｧ縺ｯ縺ゅｊ縺ｾ縺帙ｓ縲・br>
                譛ｬ繧ｵ繝ｼ繝薙せ縺ｫ蜷ｫ縺ｾ繧後ｋ諠・ｱ繧貞茜逕ｨ縺励◆縺薙→縺ｫ繧医ｊ・後Θ繝ｼ繧ｶ繝ｼ縺ｾ縺溘・隨ｬ荳芽・↓逕溘§縺滓錐螳ｳ遲峨↓縺､縺・※・悟ｽ馴°蝟ｶ縺ｯ荳蛻・・雋ｬ莉ｻ繧定ｲ縺・∪縺帙ｓ縲ょｮ昴￥縺倥・雉ｼ蜈･縺翫ｈ縺ｳ莠域Φ縺ｯ閾ｪ蟾ｱ雋ｬ莉ｻ縺ｧ縺企｡倥＞縺・◆縺励∪縺吶・/p>

                <p>髯・援・壽悽隕冗ｴ・・2026蟷ｴ4譛・0譌･縺九ｉ譁ｽ陦後＠縺ｾ縺吶・/p>
            </div>
        </div>
    </div>

    <!-- 縺雁撫縺・粋繧上○繝ｻ繝｢繝ｼ繝繝ｫ -->
    <div id="contactModal" class="pp-modal-overlay">
        <div class="pp-modal-content" style="max-width: 500px;">
            <div class="pp-modal-header">
                <h2>笨会ｸ・縺雁撫縺・粋繧上○</h2>
                <button class="pp-close" onclick="closeContact()">&times;</button>
            </div>
            <div class="pp-body">
                <form id="contactForm" onsubmit="submitContactForm(event)">
                    <div style="margin-bottom: 15px;">
                        <label style="display:block; font-size:12px; margin-bottom:5px; font-weight:bold;">縺雁錐蜑・/label>
                        <input type="text" name="name" required style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; box-sizing:border-box;">
                    </div>
                    <div style="margin-bottom: 15px;">
                        <label style="display:block; font-size:12px; margin-bottom:5px; font-weight:bold;">繝｡繝ｼ繝ｫ繧｢繝峨Ξ繧ｹ</label>
                        <input type="email" name="email" required style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; box-sizing:border-box;">
                    </div>
                    <div style="margin-bottom: 15px;">
                        <label style="display:block; font-size:12px; margin-bottom:5px; font-weight:bold;">縺雁撫縺・粋繧上○蜀・ｮｹ</label>
                        <textarea name="message" required style="width:100%; height:120px; padding:10px; border:1px solid #ddd; border-radius:6px; box-sizing:border-box; resize:none;"></textarea>
                    </div>
                    <div id="contactStatus" style="display:none; font-size:12px; margin-bottom:10px; text-align:center;"></div>
                    <button type="submit" id="btnSubmitContact" class="predict-btn" style="width:100%; border:none; padding:12px; border-radius:8px; color:white; font-weight:bold; cursor:pointer;">繝｡繝・そ繝ｼ繧ｸ繧帝∽ｿ｡縺吶ｋ</button>
                </form>
            </div>
        </div>
    </div>

